# Environment Configuration for POI Blueprint Quality Inspector

# API Keys (Get from respective services)
GEMINI_API_KEY=your_gemini_api_key_here
MAPBOX_TOKEN=your_mapbox_token_here

# Feature Flags
USE_AI_SUGGESTIONS=true
USE_MAPBOX=false

# Satellite Imagery Settings
ZOOM_LEVEL=18
IMAGE_CACHE_DIR=cache/satellite_images

# Tile URL (will use Mapbox if USE_MAPBOX=true and token provided)
TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png
