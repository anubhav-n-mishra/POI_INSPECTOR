# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Map Provider (optional - defaults to OpenStreetMap)
# GOOGLE_MAPS_API_KEY=your_api_key_here

# Model Configuration
MODEL_CACHE_DIR=./models
IMAGE_CACHE_DIR=./cache/images

# Scoring Weights (0-1, must sum to 1.0)
WEIGHT_IOU=0.35
WEIGHT_LEAKAGE=0.25
WEIGHT_ROAD_OVERLAP=0.20
WEIGHT_REGULARITY=0.10
WEIGHT_ADJACENT_OVERLAP=0.10

# Processing Configuration
MAX_IMAGE_SIZE=1024
TILE_ZOOM_LEVEL=18
CACHE_EXPIRY_DAYS=7
